{
  "name": "phishing-detection-system",
  "version": "1.0.0",
  "description": "AI-Powered Phishing Detection System",
  "scripts": {
    "install:all": "npm install --prefix frontend && pip install -r backend/requirements.txt",
    "start": "concurrently \"npm run dev --prefix frontend\" \"python backend/app/main.py\"",
    "docker:up": "docker-compose up --build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
